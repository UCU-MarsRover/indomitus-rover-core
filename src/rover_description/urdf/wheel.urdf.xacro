<?xml version="1.0"?>

<robot xmlns:xacro="http://playerstage.sourceforge.net/gazebo/xmlschema/#xacro">

  <xacro:macro name="wheel" params="name x y z side base_rocker tf_prefix=''">

    <link name="${tf_prefix}${name}_wheel_mount_link">
      <inertial>
        <origin xyz="0 ${-0.145 * side} 0" rpy="0 0 0"/>
        <mass value="0.162"/>
        <inertia ixx="0.0002" ixy="0" ixz="0" iyy="0.00012" iyz="0" izz="0.00012"/>
      </inertial>
      <visual>
        <origin xyz="0 ${-0.06 * side} -0.269" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://rover_description/meshes/suspension/wheel_mount.stl" scale="0.001 ${0.001 * side} 0.001"/>
        </geometry>
        <material name="steel"/>
      </visual>
    </link>

    <joint name="${tf_prefix}${name}_wheel_mount_joint" type="revolute">
      <origin xyz="${x} ${y} ${z}" rpy="0 0 0"/>
      <parent link="${tf_prefix}${base_rocker}_rocker_link"/>
      <child link="${tf_prefix}${name}_wheel_mount_link"/>
      <axis xyz="0 0 1"/>  <!-- вертикальна вісь (Z) для steering -->
      <limit lower="${-pi/4}" upper="${pi/3}" effort="10" velocity="1"/>
    </joint>

    <link name="${tf_prefix}${name}_wheel_link">
      <visual>
        <origin xyz="0 ${-0.06 * side} 0" rpy="${-pi/2} 0 0"/> <!-- ${0.12 * side} -->
        <geometry>
          <mesh filename="package://rover_description/meshes/suspension/wheel.stl" scale="0.001 0.001 ${side * 0.001}"/>
        </geometry>
        <material name="wheel_plastic"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${pi/2 * side} 0 0"/>
        <geometry>
          <cylinder radius="0.15" length="0.12"/>
        </geometry>
        <material name="dark_plastic"/>
      </collision>
    </link>

    <joint name="${tf_prefix}${name}_wheel_joint" type="continuous">
      <origin xyz="0 0 -0.25" rpy="0 0 0"/>
      <parent link="${tf_prefix}${name}_wheel_mount_link"/>
      <child link="${tf_prefix}${name}_wheel_link"/>
      <axis xyz="0 1.0 0"/> <!-- вісь обертання колеса (Y) для rolling -->
    </joint>

  </xacro:macro>

</robot>