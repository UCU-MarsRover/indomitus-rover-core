<?xml version="1.0"?>
<sdf version="1.10">
  <model name="indomitus_s1">

    <!-- ===================== BASE ===================== -->
    <link name="base_link">
      <inertial>
        <mass>0.1</mass>
        <inertia>
          <ixx>0.01</ixx><iyy>0.01</iyy><izz>0.01</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
    </link>

    <!-- ===================== SUSPENSION BASE AXII ===================== -->
    <link name="main_body_link">
      <pose relative_to="base_link">-0.04 0 0.05 0 0 0</pose>
      <inertial>
        <mass>40.0</mass>
          <inertia>
            <ixx>0.608</ixx>
            <iyy>1.283</iyy>
            <izz>1.733</izz>
            <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
          </inertia>
      </inertial>
      <visual name="visual">
        <geometry>
          <box><size>0.6 0.4 0.2</size></box>
        </geometry>
        <material>
          <ambient>0.1 0.2 0.5 1</ambient>
          <diffuse>0.2 0.4 0.8 1</diffuse>
          <specular>0.1 0.1 0.2 1</specular>
        </material>
      </visual>
      <collision name="collision">
        <geometry>
          <box><size>0.6 0.4 0.15</size></box>
        </geometry>
      </collision>
    </link>


    <link name="suspension_base_axii_link">
      <pose relative_to="base_link">0 0 0 0 0 0</pose>
      <inertial>
        <mass>0.5</mass>
        <inertia>
          <ixx>0.5</ixx><iyy>0.5</iyy><izz>1.0</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="visual">
        <pose>0 -0.325 0 0 0 0</pose>
        <geometry>
          <mesh>
            <uri>package://indomitus_rover_description/meshes/suspension/central_axii.stl</uri>
            <scale>0.001 0.001 0.001</scale>
          </mesh>
        </geometry>
        <material>
          <ambient>0.6 0.2 0.2 1</ambient>
          <diffuse>0.4 0.4 0.4 1</diffuse>
          <specular>0.3 0.3 0.3 1</specular>
        </material>
      </visual>
      <collision name="collision">
        <geometry>
          <box><size>0.1 0.65 0.05</size></box>
        </geometry>
      </collision>
    </link>


    <joint name="suspension_base_axii_joint" type="fixed">
      <parent>base_link</parent>
      <child>suspension_base_axii_link</child>
    </joint>

    <joint name="main_body_joint" type="revolute">
      <!-- <pose relative_to="suspension_base_axii_joint">0 0.2 0 0 0 0</pose> -->
      <parent>suspension_base_axii_link</parent>
      <child>main_body_link</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-1.0</lower><upper>1.0</upper>
          <effort>10000</effort><velocity>5.0</velocity>
        </limit>
        <dynamics>
          <damping>20.0</damping>
          <friction>1.0</friction>
        </dynamics>
      </axis>
    </joint>

    <!-- ===================== LEFT ROCKER ===================== -->
    <joint name="l_rocker_joint" type="revolute">
      <pose relative_to="suspension_base_axii_link">0 0.305 0 0 0 0</pose>
      <parent>suspension_base_axii_link</parent>
      <child>l_rocker_link</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-0.5</lower><upper>0.5</upper>
          <effort>100</effort><velocity>1.0</velocity>
        </limit>
        <dynamics><damping>0.5</damping><friction>0.1</friction></dynamics>
      </axis>
    </joint>

    <link name="l_rocker_link">
      <pose relative_to="l_rocker_joint">0 0 0 0 0 0</pose>
      <inertial>
        <mass>1.0</mass>
        <inertia>
          <ixx>0.01</ixx><iyy>0.01</iyy><izz>0.01</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="visual">
        <pose>-0.55 0.02 -0.04 0 0 0</pose>
        <geometry>
          <mesh>
            <uri>package://indomitus_rover_description/meshes/suspension/rocker.stl</uri>
            <scale>0.001 0.001 0.001</scale>
          </mesh>
        </geometry>
        <material>
          <ambient>0.3 0.3 0.3 1</ambient>
          <diffuse>0.6 0.6 0.6 1</diffuse>
          <specular>0.2 0.2 0.2 1</specular>
        </material>
      </visual>
      <collision name="collision">
        <geometry>
          <box><size>1.1 0.04 0.08</size></box>
        </geometry>
      </collision>
    </link>

    <!-- ===================== RIGHT ROCKER ===================== -->
    <joint name="r_rocker_joint" type="revolute">
      <pose relative_to="suspension_base_axii_link">0 -0.305 0 0 0 0</pose>
      <parent>suspension_base_axii_link</parent>
      <child>r_rocker_link</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-0.5</lower><upper>0.5</upper>
          <effort>100</effort><velocity>1.0</velocity>
        </limit>
        <dynamics><damping>0.5</damping><friction>0.1</friction></dynamics>
      </axis>
    </joint>

    <link name="r_rocker_link">
      <pose relative_to="r_rocker_joint">0 0 0 0 0 0</pose>
      <inertial>
        <mass>1.0</mass>
        <inertia>
          <ixx>0.01</ixx><iyy>0.01</iyy><izz>0.01</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="visual">
        <pose>-0.55 0.02 -0.04 0 0 0</pose>
        <geometry>
          <mesh>
            <uri>package://indomitus_rover_description/meshes/suspension/rocker.stl</uri>
            <scale>0.001 0.001 0.001</scale>
          </mesh>
        </geometry>
        <material>
          <ambient>0.3 0.3 0.3 1</ambient>
          <diffuse>0.6 0.6 0.6 1</diffuse>
          <specular>0.2 0.2 0.2 1</specular>
        </material>
      </visual>
      <collision name="collision">
        <geometry>
          <box><size>1.1 0.04 0.08</size></box>
        </geometry>
      </collision>
    </link>

    <!-- ===================== FRONT LEFT WHEEL ===================== -->
    <joint name="fl_wheel_mount_joint" type="revolute">
      <pose relative_to="l_rocker_link">0.53 0 0 0 0 0</pose>
      <parent>l_rocker_link</parent>
      <child>fl_wheel_mount_link</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1.5708</lower><upper>1.5708</upper>
          <effort>500</effort><velocity>2</velocity>
        </limit>
        <dynamics>
          <damping>0.5</damping>
          <friction>0.3</friction>
        </dynamics>
      </axis>
    </joint>

    <link name="fl_wheel_mount_link">
      <pose relative_to="fl_wheel_mount_joint">0 0 0 0 0 0</pose>
      <inertial>
        <mass>0.162</mass>
        <inertia>
          <ixx>0.0002</ixx><iyy>0.00012</iyy><izz>0.00012</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="visual">
        <pose>0 -0.06 -0.269 0 0 0</pose>
        <geometry>
          <mesh>
            <uri>package://indomitus_rover_description/meshes/suspension/wheel_mount.stl</uri>
            <scale>0.001 0.001 0.001</scale>
          </mesh>
        </geometry>
        <material>
          <ambient>0.6 0.3 0.0 1</ambient>
          <diffuse>0.8 0.4 0.0 1</diffuse>
          <specular>0.1 0.1 0.1 1</specular>
        </material>
      </visual>
      <collision name="collision">
        <pose>0 0.11125 -0.18 0 0 0</pose>
        <geometry>
          <box><size>0.07 0.0625 0.25</size></box>
        </geometry>
      </collision>
    </link>

    <joint name="fl_wheel_joint" type="revolute">
      <pose relative_to="fl_wheel_mount_link">0 0 -0.27 0 0 0</pose>
      <parent>fl_wheel_mount_link</parent>
      <child>fl_wheel_link</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-1e+16</lower><upper>1e+16</upper>
          <effort>100</effort><velocity>10</velocity>
        </limit>
      </axis>
    </joint>

    <link name="fl_wheel_link">
      <pose relative_to="fl_wheel_joint">0 0 0 0 0 0</pose>
      <inertial>
        <mass>0.5</mass>
        <inertia>
          <ixx>0.00563</ixx><iyy>0.00563</iyy><izz>0.01125</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="visual">
        <pose>0 -0.06 0 -1.5708 0 0</pose>
        <geometry>
          <mesh>
            <uri>package://indomitus_rover_description/meshes/suspension/wheel.stl</uri>
            <scale>0.001 0.001 0.001</scale>
          </mesh>
        </geometry>
        <material>
          <ambient>0.05 0.05 0.05 1</ambient>
          <diffuse>0.1 0.1 0.1 1</diffuse>
          <specular>0.05 0.05 0.05 1</specular>
        </material>
      </visual>
      <collision name="collision">
        <pose>0 0 0 1.5708 0 0</pose>
        <geometry>
          <cylinder><radius>0.15</radius><length>0.12</length></cylinder>
        </geometry>
      </collision>
    </link>

    <!-- ===================== FRONT RIGHT WHEEL ===================== -->
    <joint name="fr_wheel_mount_joint" type="revolute">
      <pose relative_to="r_rocker_link">0.53 0 0 0 0 0</pose>
      <parent>r_rocker_link</parent>
      <child>fr_wheel_mount_link</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1.5708</lower><upper>1.5708</upper>
          <effort>500</effort><velocity>2</velocity>
        </limit>
        <dynamics>
          <damping>0.5</damping>
          <friction>0.3</friction>
        </dynamics>
      </axis>
    </joint>

    <link name="fr_wheel_mount_link">
      <pose relative_to="fr_wheel_mount_joint">0 0 0 0 0 0</pose>
      <inertial>
        <mass>0.162</mass>
        <inertia>
          <ixx>0.0002</ixx><iyy>0.00012</iyy><izz>0.00012</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="visual">
        <pose>0 0.06 -0.269 0 0 3.14159</pose>
        <geometry>
          <mesh>
            <uri>package://indomitus_rover_description/meshes/suspension/wheel_mount.stl</uri>
            <scale>0.001 0.001 0.001</scale>
          </mesh>
        </geometry>
        <material>
          <ambient>0.6 0.3 0.0 1</ambient>
          <diffuse>0.8 0.4 0.0 1</diffuse>
          <specular>0.1 0.1 0.1 1</specular>
        </material>
      </visual>
      <collision name="collision">
        <pose>0 -0.11125 -0.18 0 0 0</pose>
        <geometry>
          <box><size>0.07 0.0625 0.25</size></box>
        </geometry>
      </collision>
    </link>

    <joint name="fr_wheel_joint" type="revolute">
      <pose relative_to="fr_wheel_mount_link">0 0 -0.27 0 0 0</pose>
      <parent>fr_wheel_mount_link</parent>
      <child>fr_wheel_link</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-1e+16</lower><upper>1e+16</upper>
          <effort>100</effort><velocity>10</velocity>
        </limit>
      </axis>
    </joint>

    <link name="fr_wheel_link">
      <pose relative_to="fr_wheel_joint">0 0 0 0 0 0</pose>
      <inertial>
        <mass>0.5</mass>
        <inertia>
          <ixx>0.00563</ixx><iyy>0.00563</iyy><izz>0.01125</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="visual">
        <pose>0 0.06 0 -1.5708 0 3.14159</pose>
        <geometry>
          <mesh>
            <uri>package://indomitus_rover_description/meshes/suspension/wheel.stl</uri>
            <scale>0.001 0.001 0.001</scale>
          </mesh>
        </geometry>
        <material>
          <ambient>0.05 0.05 0.05 1</ambient>
          <diffuse>0.1 0.1 0.1 1</diffuse>
          <specular>0.05 0.05 0.05 1</specular>
        </material>
      </visual>
      <collision name="collision">
        <pose>0 0 0 -1.5708 0 0</pose>
        <geometry>
          <cylinder><radius>0.15</radius><length>0.12</length></cylinder>
        </geometry>
      </collision>
    </link>

    <!-- ===================== BACK LEFT WHEEL ===================== -->
    <joint name="bl_wheel_mount_joint" type="revolute">
      <pose relative_to="l_rocker_link">-0.53 0 0 0 0 0</pose>
      <parent>l_rocker_link</parent>
      <child>bl_wheel_mount_link</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1.5708</lower><upper>1.5708</upper>
          <effort>500</effort><velocity>2</velocity>
        </limit>
        <dynamics>
          <damping>0.5</damping>
          <friction>0.3</friction>
        </dynamics>
      </axis>
    </joint>

    <link name="bl_wheel_mount_link">
      <pose relative_to="bl_wheel_mount_joint">0 0 0 0 0 0</pose>
      <inertial>
        <mass>0.162</mass>
        <inertia>
          <ixx>0.0002</ixx><iyy>0.00012</iyy><izz>0.00012</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="visual">
        <pose>0 -0.06 -0.269 0 0 0</pose>
        <geometry>
          <mesh>
            <uri>package://indomitus_rover_description/meshes/suspension/wheel_mount.stl</uri>
            <scale>0.001 0.001 0.001</scale>
          </mesh>
        </geometry>
        <material>
          <ambient>0.6 0.3 0.0 1</ambient>
          <diffuse>0.8 0.4 0.0 1</diffuse>
          <specular>0.1 0.1 0.1 1</specular>
        </material>
      </visual>
      <collision name="collision">
        <pose>0 0.11125 -0.18 0 0 0</pose>
        <geometry>
          <box><size>0.07 0.0625 0.25</size></box>
        </geometry>
      </collision>
    </link>

    <joint name="bl_wheel_joint" type="revolute">
      <pose relative_to="bl_wheel_mount_link">0 0 -0.27 0 0 0</pose>
      <parent>bl_wheel_mount_link</parent>
      <child>bl_wheel_link</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-1e+16</lower><upper>1e+16</upper>
          <effort>100</effort><velocity>10</velocity>
        </limit>
      </axis>
    </joint>

    <link name="bl_wheel_link">
      <pose relative_to="bl_wheel_joint">0 0 0 0 0 0</pose>
      <inertial>
        <mass>0.5</mass>
        <inertia>
          <ixx>0.00563</ixx><iyy>0.00563</iyy><izz>0.01125</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="visual">
        <pose>0 -0.06 0 -1.5708 0 0</pose>
        <geometry>
          <mesh>
            <uri>package://indomitus_rover_description/meshes/suspension/wheel.stl</uri>
            <scale>0.001 0.001 0.001</scale>
          </mesh>
        </geometry>
        <material>
          <ambient>0.05 0.05 0.05 1</ambient>
          <diffuse>0.1 0.1 0.1 1</diffuse>
          <specular>0.05 0.05 0.05 1</specular>
        </material>
      </visual>
      <collision name="collision">
        <pose>0 0 0 1.5708 0 0</pose>
        <geometry>
          <cylinder><radius>0.15</radius><length>0.12</length></cylinder>
        </geometry>
      </collision>
    </link>

    <!-- ===================== BACK RIGHT WHEEL ===================== -->
    <joint name="br_wheel_mount_joint" type="revolute">
      <pose relative_to="r_rocker_link">-0.53 0 0 0 0 0</pose>
      <parent>r_rocker_link</parent>
      <child>br_wheel_mount_link</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1.5708</lower><upper>1.5708</upper>
          <effort>500</effort><velocity>2</velocity>
        </limit>
        <dynamics>
          <damping>0.5</damping>
          <friction>0.3</friction>
        </dynamics>
      </axis>
    </joint>

    <link name="br_wheel_mount_link">
      <pose relative_to="br_wheel_mount_joint">0 0 0 0 0 0</pose>
      <inertial>
        <mass>0.162</mass>
        <inertia>
          <ixx>0.0002</ixx><iyy>0.00012</iyy><izz>0.00012</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="visual">
        <pose>0 0.06 -0.269 0 0 3.14159</pose>
        <geometry>
          <mesh>
            <uri>package://indomitus_rover_description/meshes/suspension/wheel_mount.stl</uri>
            <scale>0.001 0.001 0.001</scale>
          </mesh>
        </geometry>
        <material>
          <ambient>0.6 0.3 0.0 1</ambient>
          <diffuse>0.8 0.4 0.0 1</diffuse>
          <specular>0.1 0.1 0.1 1</specular>
        </material>
      </visual>
      <collision name="collision">
        <pose>0 -0.11125 -0.18 0 0 0</pose>
        <geometry>
          <box><size>0.07 0.0625 0.25</size></box>
        </geometry>
      </collision>
    </link>

    <joint name="br_wheel_joint" type="revolute">
      <pose relative_to="br_wheel_mount_link">0 0 -0.27 0 0 0</pose>
      <parent>br_wheel_mount_link</parent>
      <child>br_wheel_link</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-1e+16</lower><upper>1e+16</upper>
          <effort>100</effort><velocity>10</velocity>
        </limit>
      </axis>
    </joint>

    <link name="br_wheel_link">
      <pose relative_to="br_wheel_joint">0 0 0 0 0 0</pose>
      <inertial>
        <mass>0.5</mass>
        <inertia>
          <ixx>0.00563</ixx><iyy>0.00563</iyy><izz>0.01125</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="visual">
        <pose>0 0.06 0 -1.5708 0 3.14159</pose>
        <geometry>
