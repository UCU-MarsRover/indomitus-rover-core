<?xml version="1.0"?>

<robot xmlns:xacro="https://www.ros.org/wiki/xacro">

  <xacro:macro name="rocker" params="name xyz side base_axii tf_prefix=''">

    <link name="${tf_prefix}${name}_rocker_link">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="1.0"/>
        <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
      </inertial>
      <visual>
        <origin xyz="-0.55 ${0.02 * side} -0.04" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://indomitus_rover_description/meshes/suspension/rocker.stl" scale="0.001 ${0.001 * side} 0.001"/>
        </geometry>
        <material name="steel"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <!-- <origin xyz="-0.55 ${0.02 * side} -0.04" rpy="0 0 0"/> -->
        <geometry>
          <box size="1.1 ${0.04 * side} 0.08"/> <!-- приблизно вдвічі масштаб visual -->
        </geometry>
      </collision>
    </link>

    <joint name="${tf_prefix}${name}_rocker_joint" type="continuous">
      <origin xyz="${xyz}" rpy="0 0 0"/>
      <parent link="${tf_prefix}${base_axii}"/>
      <child link="${tf_prefix}${name}_rocker_link"/>
      <axis xyz="0 1.0 0"/>
      <limit effort="100" velocity="1.0"/>
      <dynamics damping="0.5" friction="0.1"/>
    </joint>

  </xacro:macro>

</robot>
