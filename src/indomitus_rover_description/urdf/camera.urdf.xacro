<?xml version="1.0"?>
<robot xmlns:xacro="https://www.ros.org/wiki/xacro">

  <xacro:macro name="camera" params="tf_prefix:='' parent_link:='base_link'">

    <link name="${tf_prefix}camera_link">
      <inertial>
        <mass value="0.1"/>
        <origin xyz="0 0 0"/>
        <inertia ixx="0.001" iyy="0.001" izz="0.001"
                 ixy="0" ixz="0" iyz="0"/>
      </inertial>

      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.05 0.05 0.05"/>
        </geometry>
        <material name="camera_visual">
          <color rgba="0 0 1 1"/>
        </material>
      </visual>

      <collision>
        <geometry>
          <box size="0.05 0.05 0.05"/>
        </geometry>
      </collision>
    </link>

    <joint name="${tf_prefix}camera_joint" type="fixed">
      <parent link="${tf_prefix}${parent_link}"/>
      <child link="${tf_prefix}camera_link"/>
      <origin xyz="0.3 0 0.6" rpy="0 0 0"/>
    </joint>

    <gazebo reference="${tf_prefix}camera_link">
    <sensor name="${tf_prefix}camera_rgb" type="camera">
        <always_on>true</always_on>
        <update_rate>30</update_rate>
        <camera>
        <horizontal_fov>1.396</horizontal_fov>
        <image>
            <width>640</width>
            <height>480</height>
            <format>R8G8B8</format>
        </image>
        <clip>
            <near>0.1</near>
            <far>100.0</far>
        </clip>
        </camera>
    </sensor>
    </gazebo>

  </xacro:macro>

</robot>